# Public contact info (shown in Contact section)
SITE_CONTACT_EMAIL=contato@infracode.tech
SITE_WHATSAPP_NUMBER=5568999999999
SITE_WHATSAPP_MESSAGE=Ola! Vim pelo site da InfraCode e gostaria de conversar sobre um projeto.
SITE_INSTAGRAM_URL=https://www.instagram.com/infracode_br?igsh=aDVoeHFkZWR1ZWd2
SITE_JURISPOCKET_URL=

# Contact form delivery (choose at least one option)
# Option A: Resend (recommended)
RESEND_API_KEY=
CONTACT_EMAIL_FROM=
CONTACT_EMAIL_TO=

# Option B: Webhook fallback
CONTACT_WEBHOOK_URL=

# Option C: external WhatsApp API with Baileys (recommended)
WHATSAPP_BAILEYS_API_URL=
WHATSAPP_BAILEYS_API_KEY=

# Option D: WhatsApp Cloud API notifications (official Meta API, fallback)
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_NOTIFY_TO=
WHATSAPP_SEND_CLIENT_ACK=true
WHATSAPP_CLIENT_ACK_MESSAGE=Recebemos sua mensagem na InfraCode. Em breve nosso time entra em contato.
WHATSAPP_CLIENT_ACK_TEMPLATE_NAME=
WHATSAPP_CLIENT_ACK_TEMPLATE_LANG=pt_BR
