{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "inputs": [
        {
          "step": "packages:mise"
        },
        {
          "local": true,
          "include": [
            "."
          ]
        }
      ],
      "commands": [
        "npm install --include=dev --no-audit --no-fund"
      ]
    },
    "build": {
      "inputs": [
        {
          "step": "install"
        }
      ],
      "commands": [
        "npm run build"
      ]
    }
  },
  "deploy": {
    "startCommand": "npm run start"
  }
}
