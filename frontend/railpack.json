{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": ["npm install --include=dev --no-audit --no-fund"],
      "inputs": [
        "$packages:mise",
        "package.json",
        "package-lock.json",
        "services/whatsapp-api/package.json"
      ]
    },
    "build": {
      "commands": ["npm run build"],
      "inputs": ["$steps:install", "."]
    }
  },
  "deploy": {
    "startCommand": "npm run start"
  }
}
