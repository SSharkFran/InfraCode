{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": ["npm install --include=dev --no-audit --no-fund"],
      "inputs": [
        {
          "local": true,
          "include": ["package.json", "package-lock.json", "services/whatsapp-api/package.json"]
        }
      ]
    },
    "build": {
      "commands": ["npm run build"],
      "inputs": [
        {
          "step": "install"
        },
        {
          "local": true,
          "include": ["."]
        }
      ]
    }
  },
  "deploy": {
    "startCommand": "npm run start"
  }
}
